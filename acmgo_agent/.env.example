# ACMGO AI Agent 配置文件示例
# 复制此文件为 .env 并填入你的实际配置

# ============================================
# LLM 提供商配置
# ============================================

# LLM 提供商选择：anthropic, openai, 或 litellm
ACMGO_PROVIDER=litellm

# 模型名称
# LiteLLM 支持的模型示例：
#   - anthropic/claude-opus-4-6
#   - anthropic/claude-sonnet-4-6
#   - openai/gpt-4o
#   - openai/gpt-4-turbo
#   - google/gemini-pro
#   - cohere/command-r
ACMGO_MODEL=anthropic/claude-opus-4-6

# ============================================
# API 密钥配置
# ============================================

# Anthropic API 密钥（用于 anthropic/ 模型）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API 密钥（用于 openai/ 模型）
OPENAI_API_KEY=sk-xxxxx

# Google API 密钥（用于 google/ 模型）
GOOGLE_API_KEY=your-google-api-key

# Cohere API 密钥（用于 cohere/ 模型）
COHERE_API_KEY=your-cohere-api-key

# 通用 API 密钥（备用，适用于不支持特定提供商的模型）
LITELLM_API_KEY=your-api-key

# ============================================
# 工作目录配置
# ============================================

# 题目输出目录
ACMGO_WORK_DIR=./problems/new_problem

# ============================================
# Agent 行为配置
# ============================================

# 自愈机制最大重试次数
ACMGO_MAX_RETRIES=3

# 是否自动进入下一步（无需确认）
ACMGO_AUTO_PROGRESS=false

# 是否显示详细输出
ACMGO_VERBOSE=true

# ============================================
# 压力测试配置
# ============================================

# 压力测试轮数
ACMGO_STRESS_TRIALS=1000

# 压力测试 N 的最大值（小数据模式）
ACMGO_STRESS_N_MAX=100

# 压力测试 T 的最大值
ACMGO_STRESS_T_MAX=3

# ============================================
# 测试数据生成配置
# ============================================

# 生成测试用例数量
ACMGO_TEST_COUNT=20

# ============================================
# 速率限制配置
# ============================================

# 最小请求间隔（秒），默认 0.05 = 20 req/s
ACMGO_RATE_LIMIT_MIN_INTERVAL=0.05

# ============================================
# 编译器配置
# ============================================

# C++ 编译器
ACMGO_COMPILER=g++
